{
  "name": "n8n-nodes-resilience",
  "version": "0.1.1",
  "description": "n8n community nodes for retry decisions, concurrency control, and dead-letter handling",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "resilience",
    "retry",
    "concurrency",
    "dead-letter-queue"
  ],
  "license": "MIT",
  "homepage": "https://github.com/tjava/n8n-nodes-resilience",
  "author": {
    "name": "Taiwo Hassan",
    "email": "devtaiwo@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjava/n8n-nodes-resilience.git"
  },
  "main": "dist/nodes/RetryStrategy/RetryStrategy.node.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "lintfix": "npm run lint:fix",
    "release": "n8n-node release",
    "format": "prettier --write \"**/*.ts\""
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/RetryStrategy/RetryStrategy.node.js",
      "dist/nodes/ConcurrencyGate/ConcurrencyGate.node.js",
      "dist/nodes/DeadLetterQueue/DeadLetterQueue.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.30.1",
    "@types/node": "^18.16.0",
    "eslint": "^9.39.1",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "change-case": "4.1.2"
  }
}
