{
  "name": "n8n-nodes-resilience",
  "version": "0.1.4",
  "description": "n8n community nodes for retry decisions, concurrency control, and dead-letter handling",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "resilience",
    "retry",
    "concurrency",
    "dead-letter-queue"
  ],
  "license": "MIT",
  "homepage": "https://github.com/tjava/n8n-nodes-resilience",
  "author": {
    "name": "Taiwo Hassan",
    "email": "devtaiwo@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjava/n8n-nodes-resilience.git"
  },
  "main": "dist/nodes/Resilience/Resilience.node.js",
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/copy-static-assets.mjs",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lintfix": "npm run lint:fix",
    "release": "npm publish --provenance --access public",
    "format": "prettier --write \"**/*.ts\""
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/Resilience/Resilience.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@n8n/eslint-plugin-community-nodes": "0.22.0",
    "@types/node": "^18.16.0",
    "eslint": "9.29.0",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import-x": "^4.15.2",
    "eslint-plugin-n8n-nodes-base": "1.16.7",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.35.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
